# SeatGeek API credentials
SEATGEEK_CLIENT_ID=          # required — your SeatGeek client ID
SEATGEEK_CLIENT_SECRET=      # optional — your SeatGeek client secret
SEATGEEK_AFFILIATE_ID=       # optional — appended to ticket URLs when set

# Bandsintown API
BANDSINTOWN_APP_ID=           # your app name string, free tier

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@ticketalert.co

# Admin dashboard
ADMIN_PASSWORD=
ADMIN_EMAIL=griffin@ticketalert.co

# Cron authentication secret — must match Authorization: Bearer header sent by Vercel cron
CRON_SECRET=

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://ticketalert.co
