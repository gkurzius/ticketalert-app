# Ticketmaster Discovery API
TICKETMASTER_API_KEY=          # required — your Ticketmaster API key

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@ticketalert.co

# Admin dashboard
ADMIN_PASSWORD=
